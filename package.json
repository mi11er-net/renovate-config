{
  "name": "@mi11er/renovate-config",
  "version": "1.5.0",
  "description": "Renovate config for mi11er.net projects.",
  "keywords": [
    "renovate",
    "renovate-config"
  ],
  "homepage": "https://github.com/mi11er-net/renovate-config",
  "bugs": {
    "url": "https://github.com/mi11er-net/renovate-config/issues"
  },
  "repository": "https://github.com/mi11er-net/renovate-config.git",
  "license": "MIT",
  "author": "Matthew Miller <matthew@mi11er.net> (https://mi11er.net)",
  "type": "module",
  "files": [
    "default.json",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "pretty-quick": "pretty-quick --staged",
    "sort-package-json": "sort-package-json",
    "pretest": "run-s lint",
    "test": "run-s validate",
    "validate": "renovate-config-validator default.json"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@mi11er/eslint-config": "^3.0.5",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-n": "^18.0.0",
    "eslint-plugin-no-unsanitized": "^4.0.0",
    "eslint-plugin-optimize-regex": "^1.1.5",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "npm-run-all2": "^9.0.0",
    "prettier": "^3.0.0",
    "pretty-quick": "^4.0.0",
    "renovate": "^43.0.0",
    "sort-package-json": "^4.0.0"
  },
  "renovate": {
    "extends": [
      "github>mi11er-net/renovate-config"
    ]
  }
}
